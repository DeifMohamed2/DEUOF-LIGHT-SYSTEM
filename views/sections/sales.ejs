<% if (mode === 'list') { %>
<% var qParam = typeof searchQ === 'string' ? searchQ : ''; %>
<% var qSuffix = qParam ? '&q=' + encodeURIComponent(qParam) : ''; %>
<div class="page-head page-head--split">
  <div>
    <h1 class="page-title">المبيعات</h1>
    <p class="muted"><%= isAdmin ? 'كل المبيعات' : 'مبيعاتك المسجلة' %> — بحث بإذن الصرف، العميل، الأصناف، الإجمالي…</p>
  </div>
  <a href="/sales/new" class="btn btn--primary">تسجيل مبيعة</a>
</div>

<div class="toolbar">
  <form method="get" action="/sales" class="toolbar__form toolbar__form--grow">
    <input type="search" name="q" class="form__input form__input--search" placeholder="ابحث: إذن صرف، اسم عميل، رقم عميل، صنف، كود، إجمالي…" value="<%= qParam %>" autocomplete="off">
    <button type="submit" class="btn">بحث</button>
    <% if (qParam) { %><a class="btn btn--ghost" href="/sales">مسح</a><% } %>
  </form>
</div>

<% if (!sales.length) { %>
  <div class="panel empty"><%= qParam ? 'لا توجد مبيعات مطابقة للبحث.' : 'لا توجد مبيعات.' %></div>
<% } else { %>
<div class="table-wrap">
<table class="table">
  <thead>
    <tr>
      <th>رقم إذن الصرف</th>
      <th>التاريخ</th>
      <th>العميل</th>
      <th>الإجمالي (ج.م)</th>
      <% if (isAdmin) { %><th>المستخدم</th><% } %>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% sales.forEach(function (s) { %>
    <tr>
      <td><%= s.disbursementNumber && String(s.disbursementNumber).trim() ? s.disbursementNumber : '—' %></td>
      <td><%= new Date(s.soldAt).toLocaleString('ar-EG') %></td>
      <td><%= s.customerName && String(s.customerName).trim() ? s.customerName : '—' %></td>
      <td><%= Number(s.total).toFixed(2) %> ج.م</td>
      <% if (isAdmin) { %>
      <td><%= s.createdBy && (s.createdBy.fullName || s.createdBy.username) || '—' %></td>
      <% } %>
      <td class="nowrap">
        <a class="link" href="/sales/<%= s._id %>">تفاصيل</a>
        <% var sCreator = s.createdBy && s.createdBy._id ? String(s.createdBy._id) : ''; %>
        <% if (isAdmin || (typeof listUserId !== 'undefined' && sCreator === String(listUserId))) { %>
        · <a class="link" href="/sales/<%= s._id %>/edit">تعديل</a>
        · <form class="form--inline-delete" method="post" action="/sales/<%= s._id %>/delete" onsubmit="return confirm('حذف المبيعة وإرجاع كميات المخزن؟ لا يمكن التراجع.');">
          <button type="submit" class="link link--danger btn-as-text">حذف</button>
        </form>
        <% } %>
      </td>
    </tr>
    <% }) %>
  </tbody>
</table>
</div>
<div class="pagination">
  <% if (page > 1) { %>
  <a class="btn btn--sm" href="?page=<%= page - 1 %><%= qSuffix %>">السابق</a>
  <% } %>
  <span class="muted">صفحة <%= page %> من <%= totalPages %></span>
  <% if (page < totalPages) { %>
  <a class="btn btn--sm" href="?page=<%= page + 1 %><%= qSuffix %>">التالي</a>
  <% } %>
</div>
<% } %>

<% } else if (mode === 'new') { %>
<div class="page-head">
  <h1 class="page-title">تسجيل مبيعة</h1>
  <a href="/sales" class="link">رجوع</a>
</div>
<div class="panel">
  <p class="muted">ابحث في المخزن لإضافة صنف يُخصم من الكمية المتاحة، أو استخدم «إضافة سطر يدوي» لبيع صنف غير مسجل في المخزن (بدون خصم مخزون).</p>
  <div class="inventory-picker">
    <div class="inventory-picker__row">
      <input type="search" id="sale-search" class="form__input form__input--search inventory-picker__input" placeholder="ابحث في المخزن (كود أو اسم أو بند)…" autocomplete="off" aria-autocomplete="list" aria-controls="sale-pick-results">
      <button type="button" class="btn btn--ghost btn--sm inventory-picker__clear" id="sale-search-clear" aria-label="مسح البحث">مسح</button>
    </div>
    <div id="sale-pick-results" class="pick-results" role="listbox" aria-label="نتائج البحث في المخزن"></div>
  </div>
  <form class="form" method="post" action="/sales" id="sale-form">
    <input type="hidden" name="linesJson" id="linesJson">

    <h3 class="form__section-title">بيانات العميل والدفع</h3>
    <label class="form__label">اسم العميل / الجهة</label>
    <input class="form__input" name="customerName" required autocomplete="organization">

    <label class="form__label">رقم إذن الصرف</label>
    <input class="form__input" name="disbursementNumber" required maxlength="200" inputmode="numeric" autocomplete="off" value="<%= typeof suggestedDisbursementNumber !== 'undefined' ? suggestedDisbursementNumber : '1' %>">
    <p class="muted form__hint">يُقترح تلقائياً كالتالي بعد آخر رقم رقمي مسجّل (مثال: بعد 1201 يظهر 1202). يمكنك التعديل عند الحاجة.</p>

    <label class="form__label">رقم العميل</label>
    <input class="form__input" name="customerNumber" placeholder="كود أو رقم مرجعي (اختياري)" maxlength="200">

    <label class="form__label" for="sale-payment-method">طريقة الدفع</label>
    <select class="form__input" id="sale-payment-method" name="paymentMethod" required>
      <option value="" disabled selected>— اختر طريقة الدفع —</option>
      <% (salePaymentMethods || []).forEach(function (opt) { %>
      <option value="<%= opt.value %>"><%= opt.label %></option>
      <% }) %>
    </select>

    <label class="form__label">ملاحظة دفع إضافية (اختياري)</label>
    <input class="form__input" name="paymentNote" maxlength="2000">

    <label class="form__check-row">
      <input type="checkbox" name="vat14" id="sale-vat14" value="1">
      <span>أضف ١٤٪ ضريبة قيمة مضافة على إجمالي البنود</span>
    </label>
    <label class="form__check-row">
      <input type="checkbox" name="noticeDiscount" id="sale-notice-discount" value="1">
      <span>خصم ١٪ إشعار من مجموع البنود (قبل الضريبة)</span>
    </label>

    <h3 class="form__section-title">بنود المبيعة</h3>
    <div class="form__stock-tools">
      <button type="button" class="btn btn--sm" id="sale-add-manual">+ إضافة سطر يدوي</button>
      <span class="muted form__stock-tools-hint">لصنف غير موجود في المخزن — لن يُخصم من المخزون</span>
    </div>
    <div class="table-wrap">
    <table class="table table--compact">
      <thead>
        <tr>
          <th>المصدر</th>
          <th>الكود</th>
          <th>الاسم</th>
          <th>الكمية</th>
          <th>سعر الوحدة (ج.م)</th>
          <th>الإجمالي (ج.م)</th>
          <th></th>
        </tr>
      </thead>
      <tbody id="lines-body"></tbody>
    </table>
    </div>
    <div id="sale-totals-wrap" class="sale-totals-preview sale-totals-preview--rtl" hidden>
      <p class="total-line sale-totals-preview__vat muted" id="sale-line-vat" hidden>ضريبة القيمة المضافة (١٤٪): <strong id="tv-vat">0.00</strong> ج.م</p>
      <p class="total-line sale-totals-preview__vat muted" id="sale-line-notice" hidden>خصم ١٪ إشعار: <strong id="tv-notice">0.00</strong> ج.م</p>
      <p class="total-line sale-totals-preview__final"><span id="tv-final-label">الإجمالي</span>: <strong id="tv-final">0.00</strong> ج.م</p>
    </div>
    <div class="form__actions">
      <button type="submit" class="btn btn--primary">تأكيد المبيعة</button>
    </div>
  </form>
</div>
<script src="/js/inventorySearchPicker.js"></script>
<script>
(function () {
  var body = document.getElementById('lines-body');
  var form = document.getElementById('sale-form');
  var hidden = document.getElementById('linesJson');
  var totalsWrap = document.getElementById('sale-totals-wrap');
  var lineVat = document.getElementById('sale-line-vat');
  var lineNotice = document.getElementById('sale-line-notice');
  var tvVat = document.getElementById('tv-vat');
  var tvNotice = document.getElementById('tv-notice');
  var tvFinal = document.getElementById('tv-final');
  var tvFinalLabel = document.getElementById('tv-final-label');
  var vatCb = document.getElementById('sale-vat14');
  var noticeCb = document.getElementById('sale-notice-discount');
  var btnManual = document.getElementById('sale-add-manual');
  var VAT = 0.14;
  var NOTICE_DISCOUNT = 0.01;
  if (!body || !form || !hidden) return;
  function recalc() {
    var sum = 0;
    Array.prototype.forEach.call(body.querySelectorAll('tr'), function (tr) {
      var q = Number(tr.querySelector('[data-f=quantity]').value) || 0;
      var p = Number(tr.querySelector('[data-f=unitPrice]').value) || 0;
      sum += q * p;
      var lt = tr.querySelector('[data-f=lineTotal]');
      if (lt) lt.textContent = (q * p).toFixed(2) + ' ج.م';
    });
    sum = Math.round(sum * 100) / 100;
    var hasRows = body.querySelectorAll('tr').length > 0;
    totalsWrap.hidden = !hasRows;
    if (!hasRows) return;
    var vatOn = vatCb && vatCb.checked;
    var noticeOn = noticeCb && noticeCb.checked;
    var vatAmt = vatOn ? Math.round(sum * VAT * 100) / 100 : 0;
    var noticeAmt = noticeOn ? Math.round(sum * NOTICE_DISCOUNT * 100) / 100 : 0;
    var finalVal = Math.max(0, Math.round((sum + vatAmt - noticeAmt) * 100) / 100);
    if (lineVat) lineVat.hidden = !vatOn;
    if (tvVat) tvVat.textContent = vatAmt.toFixed(2);
    if (lineNotice) lineNotice.hidden = !noticeOn;
    if (tvNotice) tvNotice.textContent = noticeAmt.toFixed(2);
    if (tvFinal) tvFinal.textContent = finalVal.toFixed(2);
    if (tvFinalLabel) tvFinalLabel.textContent = vatOn || noticeOn ? 'الإجمالي النهائي' : 'الإجمالي';
  }
  if (vatCb) vatCb.addEventListener('change', recalc);
  if (noticeCb) noticeCb.addEventListener('change', recalc);
  function esc(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/"/g,'&quot;');
  }
  function bindRemove(tr) {
    tr.querySelector('.rm').onclick = function () { tr.remove(); recalc(); };
  }
  function wireInputs(tr) {
    tr.querySelectorAll('[data-f=quantity], [data-f=unitPrice]').forEach(function (el) {
      el.addEventListener('input', recalc);
    });
  }
  function addLineFromStock(item) {
    var tr = document.createElement('tr');
    tr.setAttribute('data-line-source', 'stock');
    tr.innerHTML =
      '<td><span class="sale-line-badge sale-line-badge--stock">مخزن</span></td>' +
      '<td><code>' + esc(item.itemCode) + '</code>' +
      '<input type="hidden" data-f="inventoryItem" value="' + esc(item._id) + '">' +
      '<input type="hidden" data-f="itemCode" value="' + esc(item.itemCode) + '"></td>' +
      '<td><span data-f="itemName">' + esc(item.name) + '</span></td>' +
      '<td><input class="form__input" type="number" min="1" max="' + item.quantityOnHand + '" step="1" data-f="quantity" value="1" required></td>' +
      '<td><input class="form__input" type="number" min="0" step="0.01" data-f="unitPrice" value="' + Number(item.unitPrice || 0).toFixed(2) + '" required></td>' +
      '<td><span data-f="lineTotal">' + Number(item.unitPrice || 0).toFixed(2) + ' ج.م</span></td>' +
      '<td><button type="button" class="link link--danger rm">حذف</button></td>';
    bindRemove(tr);
    wireInputs(tr);
    body.appendChild(tr);
    recalc();
  }
  function addManualLine() {
    var tr = document.createElement('tr');
    tr.setAttribute('data-line-source', 'manual');
    tr.innerHTML =
      '<td><span class="sale-line-badge sale-line-badge--manual">خارج المخزن</span></td>' +
      '<td><input class="form__input" data-f="itemCode" placeholder="كود (اختياري)"></td>' +
      '<td><input class="form__input" data-f="itemName" placeholder="اسم الصنف" required></td>' +
      '<td><input class="form__input" type="number" min="1" step="1" data-f="quantity" value="1" required></td>' +
      '<td><input class="form__input" type="number" min="0" step="0.01" data-f="unitPrice" value="0" required></td>' +
      '<td><span data-f="lineTotal">0.00 ج.م</span></td>' +
      '<td><button type="button" class="link link--danger rm">حذف</button></td>';
    bindRemove(tr);
    wireInputs(tr);
    body.appendChild(tr);
    recalc();
  }
  if (btnManual) btnManual.onclick = addManualLine;
  function isDuplicateItem(item) {
    var id = String(item._id);
    var nodes = body.querySelectorAll('tr[data-line-source="stock"] [data-f=inventoryItem]');
    for (var i = 0; i < nodes.length; i++) {
      if (nodes[i].value === id) return true;
    }
    return false;
  }
  if (window.InventorySearchPicker) {
    window.InventorySearchPicker.attach({
      searchId: 'sale-search',
      resultsId: 'sale-pick-results',
      clearButtonId: 'sale-search-clear',
      debounceMs: 320,
      minLen: 1,
      isDuplicate: isDuplicateItem,
      onSelect: function (x) {
        addLineFromStock(x);
      },
    });
  }
  form.onsubmit = function () {
    var rows = Array.prototype.slice.call(body.querySelectorAll('tr'));
    var lines = rows.map(function (tr) {
      var invEl = tr.querySelector('[data-f=inventoryItem]');
      var inventoryItem = invEl && invEl.value ? invEl.value.trim() : '';
      var codeEl = tr.querySelector('[data-f=itemCode]');
      var itemCode = codeEl ? codeEl.value.trim() : '';
      var nameEl = tr.querySelector('[data-f=itemName]');
      var itemName = nameEl && nameEl.tagName === 'INPUT' ? nameEl.value.trim() : (nameEl ? nameEl.textContent.trim() : '');
      var qty = Number(tr.querySelector('[data-f=quantity]').value);
      var unitPrice = Number(tr.querySelector('[data-f=unitPrice]').value);
      if (inventoryItem) {
        return { inventoryItem: inventoryItem, itemCode: itemCode, itemName: itemName, quantity: qty, unitPrice: unitPrice };
      }
      return { itemCode: itemCode, itemName: itemName, quantity: qty, unitPrice: unitPrice };
    }).filter(function (l) {
      if (l.inventoryItem) return true;
      return Boolean(l.itemName);
    });
    hidden.value = JSON.stringify(lines);
  };
})();
</script>

<% } else if (mode === 'edit' && sale) { %>
<%- include('../partials/saleEdit') %>

<% } else if (mode === 'show' && sale) { %>
<div class="page-head page-head--split">
  <h1 class="page-title">تفاصيل المبيعة</h1>
  <div class="btn-row btn-row--wrap">
    <a class="btn" href="/sales/<%= sale._id %>/pdf" target="_blank">تحميل PDF</a>
    <% if (typeof canMutateSale !== 'undefined' && canMutateSale) { %>
    <a class="btn btn--secondary" href="/sales/<%= sale._id %>/edit">تعديل</a>
    <form method="post" action="/sales/<%= sale._id %>/delete" class="form--inline-delete" onsubmit="return confirm('حذف المبيعة وإرجاع كميات المخزن؟');">
      <button type="submit" class="btn btn--danger btn--sm">حذف</button>
    </form>
    <% } %>
    <a href="/sales" class="link">رجوع</a>
  </div>
</div>
<% var vatAppliedDetail = sale.vat14Applied === true; %>
<% var noticeAppliedDetail = sale.noticeDiscountApplied === true; %>
<% var saleHasAdjDetail = vatAppliedDetail || noticeAppliedDetail; %>
<div class="panel">
  <dl class="meta-list">
    <dt>اسم العميل</dt><dd><%= sale.customerName && String(sale.customerName).trim() ? sale.customerName : '—' %></dd>
    <dt>رقم إذن الصرف</dt><dd><%= sale.disbursementNumber && String(sale.disbursementNumber).trim() ? sale.disbursementNumber : '—' %></dd>
    <dt>رقم العميل</dt><dd><%= sale.customerNumber && String(sale.customerNumber).trim() ? sale.customerNumber : '—' %></dd>
    <dt>طريقة الدفع</dt><dd><%= typeof salePaymentDisplay !== 'undefined' && salePaymentDisplay ? salePaymentDisplay : '—' %></dd>
    <dt>التاريخ</dt><dd><%= new Date(sale.soldAt).toLocaleString('ar-EG') %></dd>
    <% if (vatAppliedDetail) { %>
    <dt>ضريبة القيمة المضافة (١٤٪)</dt><dd><%= Number(sale.vat14Amount || 0).toFixed(2) %> ج.م</dd>
    <% } %>
    <% if (noticeAppliedDetail) { %>
    <dt>خصم ١٪ إشعار</dt><dd><%= Number(sale.noticeDiscountAmount || 0).toFixed(2) %> ج.م</dd>
    <% } %>
    <% if (saleHasAdjDetail) { %>
    <dt>الإجمالي النهائي</dt><dd><strong><%= Number(sale.total).toFixed(2) %> ج.م</strong></dd>
    <% } else { %>
    <dt>الإجمالي</dt><dd><strong><%= Number(sale.total).toFixed(2) %> ج.م</strong></dd>
    <% } %>
    <dt>ملاحظة دفع</dt><dd><%= sale.paymentNote && String(sale.paymentNote).trim() ? sale.paymentNote : '—' %></dd>
    <dt>سجلها</dt><dd><%= sale.createdBy && (sale.createdBy.fullName || sale.createdBy.username) || '—' %></dd>
  </dl>
  <div class="table-wrap">
  <table class="table">
    <thead>
      <tr>
        <th>المصدر</th>
        <th>الكود</th>
        <th>الاسم</th>
        <th>الكمية</th>
        <th>سعر الوحدة (ج.م)</th>
        <th>الإجمالي (ج.م)</th>
      </tr>
    </thead>
    <tbody>
      <% sale.lines.forEach(function (line) { %>
      <% var fromInv = line.fromStock !== false && line.inventoryItem; %>
      <tr>
        <td><%= fromInv ? 'مخزن' : 'خارج المخزن' %></td>
        <td><%= line.itemCode || '—' %></td>
        <td><%= line.itemName %></td>
        <td><%= line.quantity %></td>
        <td><%= Number(line.unitPrice).toFixed(2) %> ج.م</td>
        <td><%= Number(line.lineTotal).toFixed(2) %> ج.م</td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  </div>
</div>
<% } %>
