<script>
(function () {
  var form = document.getElementById('receipt-edit-form');
  var cashIn = document.getElementById('receipt-edit-cash');
  var chequeEls = [
    document.getElementById('receipt-edit-chq-amt'),
    document.getElementById('receipt-edit-bank'),
    document.getElementById('receipt-edit-cust'),
    document.getElementById('receipt-edit-chq-num'),
    document.getElementById('receipt-edit-chq-date')
  ];
  function parseCash() {
    var t = String(cashIn && cashIn.value != null ? cashIn.value : '').replace(/,/g, '.').trim();
    var n = parseFloat(t);
    return Number.isFinite(n) ? n : 0;
  }
  function applyCashLock() {
    var lock = parseCash() > 0;
    chequeEls.forEach(function (el) {
      if (!el) return;
      el.disabled = lock;
      if (lock) {
        if (el.type === 'number') el.value = '0';
        else if (el.type === 'date') el.value = '';
        else el.value = '';
      }
    });
  }
  if (!form || !cashIn) return;
  cashIn.addEventListener('input', applyCashLock);
  cashIn.addEventListener('change', applyCashLock);
  form.addEventListener('submit', function () {
    if (parseCash() > 0) {
      chequeEls.forEach(function (el) {
        if (!el) return;
        el.disabled = false;
        if (el.type === 'number') el.value = '0';
        else if (el.type === 'date') el.value = '';
        else el.value = '';
      });
    }
  });
  applyCashLock();
})();
</script>
<% } %>
