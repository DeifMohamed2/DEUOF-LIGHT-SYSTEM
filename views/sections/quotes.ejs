<script>
(function () {
  var body = document.getElementById('lines-body-edit-req');
  var form = document.getElementById('quote-form-edit-req');
  var hidden = document.getElementById('linesJsonEditReq');
  var initialLines = <%- JSON.stringify((quote.lines || []).map(function (l) {
    return { itemCode: l.itemCode || '', itemName: l.itemName || '', quantity: l.quantity };
  })) %>;
  function escAttr(s) {
    return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;');
  }
  function addRow(prefill) {
    var tr = document.createElement('tr');
    var ic = prefill && prefill.itemCode != null ? String(prefill.itemCode) : '';
    var iname = prefill && prefill.itemName != null ? String(prefill.itemName) : '';
    var q = prefill && prefill.quantity != null ? prefill.quantity : 1;
    tr.innerHTML = '<td><input class="form__input" data-f="itemCode" value="' + escAttr(ic) + '"></td>' +
      '<td><input class="form__input" data-f="itemName" required value="' + escAttr(iname) + '"></td>' +
      '<td><input class="form__input" type="number" min="0" step="1" data-f="quantity" required value="' + escAttr(String(q)) + '"></td>' +
      '<td><button type="button" class="link link--danger rm">حذف</button></td>';
    tr.querySelector('.rm').onclick = function () { tr.remove(); };
    body.appendChild(tr);
  }
  document.getElementById('add-line-edit-req').onclick = function () { addRow(null); };
  if (initialLines.length) {
    initialLines.forEach(function (l) { addRow(l); });
  } else {
    addRow(null);
  }
  form.onsubmit = function () {
    var rows = Array.prototype.slice.call(body.querySelectorAll('tr'));
    var lines = rows.map(function (tr) {
      return {
        itemCode: tr.querySelector('[data-f=itemCode]').value.trim(),
        itemName: tr.querySelector('[data-f=itemName]').value.trim(),
        quantity: Number(tr.querySelector('[data-f=quantity]').value)
      };
    }).filter(function (l) { return l.itemName; });
    hidden.value = JSON.stringify(lines);
  };
})();
</script>

