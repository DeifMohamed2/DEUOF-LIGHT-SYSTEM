MONGODB_URI=mongodb://127.0.0.1:27017/deuof_light
SESSION_SECRET=change-this-to-a-long-random-string
PORT=3000
NODE_ENV=development

# للوصول عبر HTTP محلياً: اترك القيم الافتراضية. لا تستخدم https:// في المتصفح إلا إذا كان الخادم يقدم TLS.
# خلف بروكسي HTTPS: SESSION_COOKIE_SECURE=true و TRUST_HTTPS_PROXY=true
SESSION_COOKIE_SECURE=false
TRUST_HTTPS_PROXY=false

# PDF (Puppeteer) على Linux — الأفضل: تثبيت كروميوم النظام (يُكتشف تلقائياً):
#   sudo bash scripts/install-system-chromium.sh
# أو مكتبات كروم المُحمّل مع Puppeteer (Ubuntu 24+ يدعم أسماء t64):
#   sudo bash scripts/install-puppeteer-chrome-deps.sh
# اختياري — إجبار مسار ثنائي معيّن:
# PUPPETE_EXECUTABLE_PATH=/usr/bin/chromium
